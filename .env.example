# Copy to .env (backend) and .env.local (frontend) as appropriate. Never commit real keys.

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=            # frontend
SUPABASE_SERVICE_ROLE_KEY=    # backend only — never expose to the client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend API ---
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Email (Resend) ---
RESEND_API_KEY=
ALERT_FROM_EMAIL=

# --- Job sources (add as adapters are enabled) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Remotive / RemoteOK / Arbeitnow / ATS boards need no key.
# Comma-separated Supabase user UUIDs allowed to trigger POST /admin/fetch-jobs.
# Empty = locked (no one can trigger) — fail closed. Set your own user id here.
ADMIN_USER_IDS=

# --- Guardrails ---
PER_USER_DAILY_LLM_CAP=25
GLOBAL_MONTHLY_BUDGET_USD=50
# Coach chat is an abuse-only cap (turns are ~0.6c). Keep this generous, or leave
# it unset to use the default of 50. Do NOT set it low in production — a stray low
# value cuts off real conversations. The backend floors it at 40 regardless.
ENRICH_DAILY_TURN_CAP=50
