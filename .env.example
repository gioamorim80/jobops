# Copy to .env (backend) and .env.local (frontend) as appropriate. Never commit real keys.

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=            # frontend
SUPABASE_SERVICE_ROLE_KEY=    # backend only — never expose to the client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend API ---
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Email (Resend) ---
RESEND_API_KEY=
ALERT_FROM_EMAIL=
# Optional display name mail clients show (e.g. JobOps). Unset = bare address.
ALERT_FROM_NAME=

# --- Job sources (add as adapters are enabled) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Remotive / RemoteOK / Arbeitnow / ATS boards need no key.
# Comma-separated Supabase user UUIDs allowed to trigger POST /admin/fetch-jobs.
# Empty = locked (no one can trigger) — fail closed. Set your own user id here.
ADMIN_USER_IDS=
# Comma-separated user UUIDs exempt from the PER-USER caps (owner/test accounts).
# They still respect the global budget ceiling. Empty = nobody exempt. Set on Railway.
CAP_EXEMPT_USER_IDS=

# --- Guardrails ---
# Daily cap across ALL of a user's agent calls — a runaway/abuse brake (the monthly
# caps below do cost-fairness). Leave unset to use the default of 100.
PER_USER_DAILY_LLM_CAP=100
# Per-user monthly caps (calendar month, reset on the 1st). Score and tailor are
# capped separately, so one never blocks the other.
PER_USER_MONTHLY_SCORE_CAP=50
PER_USER_MONTHLY_TAILOR_CAP=10
# Global month-to-date budget ceiling (USD) across all users. Built but not yet
# enforced; wired to the digest scanner later. Set below the real budget on purpose
# (logged cost under-counts actual spend).
MONTHLY_BUDGET_CEILING_USD=15
# Coach chat is an abuse-only cap (turns are ~0.6c). Keep this generous, or leave
# it unset to use the default of 50. Do NOT set it low in production — a stray low
# value cuts off real conversations. The backend floors it at 40 regardless.
ENRICH_DAILY_TURN_CAP=50
